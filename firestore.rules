rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isStudent() {
      return isAuthenticated() && getUserRole() == 'student';
    }
    
    // USERS COLLECTION
    match /users/{userId} {
      // Leer: propietario o admin
      allow read: if isOwner(userId) || isAdmin();
      
      // Crear: solo durante signup
      allow create: if isOwner(userId)
                    && request.resource.data.email == request.auth.token.email;
      
      // Actualizar: propietario (excepto rol) o admin (todo)
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
                    || isAdmin();
      
      // Eliminar: solo admins
      allow delete: if isAdmin();
    }
    
    // CONVERSATIONS COLLECTION
    match /conversations/{conversationId} {
      // Leer: participantes o admin
      allow read: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid ||
        resource.data.tutorId == request.auth.uid ||
        isAdmin()
      );
      
      // Crear: usuario autenticado crea su propia consulta en estado pending
      allow create: if isAuthenticated()
                    && request.resource.data.studentId == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.tutorId == null;
      
      // Actualizar: asignación de tutor, cambio de status por tutor, o admin
      allow update: if isAuthenticated() && (
        // Permitir asignación automática de tutor (de pending a assigned)
        (resource.data.status == 'pending' && 
         request.resource.data.status == 'assigned' &&
         request.resource.data.tutorId != null) ||
        // Estudiante dueño puede actualizar (ej: marcar como completada)
        (resource.data.studentId == request.auth.uid) ||
        // Tutor asignado puede actualizar la conversación
        (resource.data.tutorId == request.auth.uid) ||
        // Admin puede todo
        isAdmin()
      );
      
      // Eliminar: solo admins
      allow delete: if isAdmin();
      
      // MESSAGES SUBCOLLECTION
      match /messages/{messageId} {
        // Leer: participantes de la conversación
        allow read: if isAuthenticated() && (
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.studentId == request.auth.uid ||
          get(/databases/$(database)/documents/conversations/$(conversationId)).data.tutorId == request.auth.uid ||
          isAdmin()
        );
        
        // Crear: mensajes del sistema o participantes
        allow create: if isAuthenticated() && (
          // Mensajes del sistema (asignación automática)
          (request.resource.data.senderId == 'system' && request.resource.data.senderRole == 'system') ||
          // Admin puede escribir en cualquier conversación
          isAdmin() ||
          // Mensajes de participantes
          (request.resource.data.senderId == request.auth.uid &&
          (
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.studentId == request.auth.uid ||
            get(/databases/$(database)/documents/conversations/$(conversationId)).data.tutorId == request.auth.uid
          ))
        );
        
        // Actualizar: nadie (mensajes inmutables)
        allow update: if false;
        
        // Eliminar: solo admins
        allow delete: if isAdmin();
      }
    }

    // OFFERS COLLECTION
    // Created and updated by the backend server (Firebase Admin SDK).
    // Frontend needs to listen in real-time; read is allowed to any authenticated
    // user (Firestore cannot evaluate resource.data in collection queries).
    match /offers/{offerId} {
      allow read: if isAuthenticated();

      // Create/Update/Delete: handled exclusively by the backend via Admin SDK.
      // Deny all client-side writes to prevent tampering with payment data.
      allow write: if false;
    }

    // NOTIFICATIONS COLLECTION
    // Written by the backend webhook handler; read by the recipient user.
    match /notifications/{notificationId} {
      // Read: only the notification owner or admin
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );

      // Mark as read: only the notification owner
      allow update: if isAuthenticated()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

      // Create/Delete: backend only
      allow create: if false;
      allow delete: if isAdmin();
    }

    // REVIEWS COLLECTION
    match /reviews/{reviewId} {
      // Public read so the ReviewsPanel can show reviews to landing-page visitors
      allow read: if true;
      // Authenticated students can submit a review tied to their own uid
      allow create: if isAuthenticated()
                    && isStudent()
                    && request.resource.data.studentId == request.auth.uid;
      // Reviews are immutable once submitted
      allow update, delete: if false;
    }

    // TAREAS COLLECTION — file upload metadata
    match /tareas/{tareaId} {
      // Read: the uploader, the tutor of that conversation, or admin
      allow read: if isAuthenticated() && (
        resource.data.uploadedBy == request.auth.uid ||
        get(/databases/$(database)/documents/conversations/$(resource.data.conversationId)).data.tutorId == request.auth.uid ||
        isAdmin()
      );
      // Create: any authenticated user, only for their own uid
      allow create: if isAuthenticated()
                    && request.resource.data.uploadedBy == request.auth.uid;
      // No client-side updates or deletes
      allow update, delete: if isAdmin();
    }

    // CONFIG COLLECTION — app-wide settings (e.g. defaultTutorId)
    match /config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
