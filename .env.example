# CONFIGURACIÓN DE FIREBASE
# Copia este archivo como .env.local y completa con tus credenciales

# Ve a https://console.firebase.google.com/
# 1. Crea un proyecto nuevo o usa uno existente
# 2. Ve a Project Settings (⚙️) > General
# 3. En "Your apps", crea una Web App
# 4. Copia los valores de configuración aquí:

VITE_FIREBASE_API_KEY=tu_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto-id
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=tu_app_id_aqui

# ─── Backend Server ───────────────────────────────────────────────────────────
# URL of the AcadeMatt backend (see server/.env.example for server setup)
VITE_API_URL=http://localhost:3001
