# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001

# URL del frontend (para CORS y redirect post-pago)
FRONTEND_URL=http://localhost:5173


# ─── Lemon Squeezy ────────────────────────────────────────────────────────────
# Obtén tu API Key en: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY=your_ls_api_key_here

# ID de tu tienda (number). Lo encuentras en el dashboard de Lemon Squeezy.
LEMONSQUEEZY_STORE_ID=12345

# ID de la variante de un producto con precio flexible (Pay What You Want o
# precio custom). Crea un producto en LS y copia el Variant ID.
LEMONSQUEEZY_VARIANT_ID=67890

# Secreto para validar firmas de webhooks.
# Configúralo en: LS Dashboard > Settings > Webhooks > agregar webhook
# URL: https://tu-servidor.com/api/webhook  |  Events: order_created
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here


# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# Descarga el Service Account JSON desde:
# Firebase Console > Project Settings > Service accounts > Generate new private key
# Guarda el archivo como server/serviceAccountKey.json  (no lo subas a git)
#
# Alternativa para deploy en Railway/Render (pega el JSON completo como string):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
